# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or app, you might want to share your .python-version.
#   Only uncomment if you do not wish to share this file.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used with a venv, it might be ignored.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is generally tracked in version control.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is generally tracked in version control.
#pdm.lock

# virtualenv
venv/
active_env/
ENV/
env.bak/
venv.bak/

# Environment variables
.env
.flaskenv

